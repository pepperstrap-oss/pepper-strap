# =============================================
# PEPPER STRAP — Contoh Environment Variables
# =============================================
# Salin file ini menjadi ".env.local" lalu isi nilai-nilai di bawah ini
# dengan kunci/API key asli dari masing-masing layanan.
# JANGAN PERNAH upload file .env.local ke GitHub!

# --- SUPABASE (Database) ---
# Ambil di: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- API.CO.ID (Cek Ongkos Kirim - Gratis) ---
# Daftar di: https://api.co.id, pilih produk "Api Cek Ongkos Kirim"
APICOID_API_KEY=

# --- RAJAONGKIR (tidak dipakai lagi, diganti api.co.id) ---
# Kode village asal toko (10 digit dari api.co.id)
RAJAONGKIR_ORIGIN_CITY_ID=

# --- MIDTRANS (Pembayaran) ---
# Daftar di: https://midtrans.com  (gunakan kunci SANDBOX dulu untuk uji coba)
MIDTRANS_SERVER_KEY=
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
# Ganti jadi "true" hanya setelah akun Midtrans disetujui untuk produksi
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# --- INFO UMUM SITUS ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME=Pepper Strap
